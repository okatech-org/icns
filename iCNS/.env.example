# ─── iCNS — Variables d'environnement (template) ───────────────────────
# Copier en `.env.local` et remplir avec les valeurs de l'environnement cible.
# Ne JAMAIS commiter le `.env.local`.

# ─── Convex (back-end) ──────────────────────────────────────────────────
# URL de l'instance Convex souveraine (à terme : déploiement on-premise GA).
# Format : https://<deployment-id>.convex.cloud
VITE_CONVEX_URL=

# ─── Firebase (auth temporaire — à supprimer en Phase 2 / Prompt 2.1) ───
# Firebase est conservé temporairement pour l'authentification.
# Migration prévue vers carte agent + PIN + biométrie (cf. cahier des charges ET-02.4).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_USE_FIREBASE_EMULATOR=false

# ─── OpenAI (assistant ChatGPT — à intégrer en remplacement de ElevenLabs) ──
# Clé API OpenAI pour le module d'assistance IA (chat, génération de notes).
# IMPORTANT : ne pas envoyer de contenu classifié DR/CD/SD/TSD vers OpenAI tant
# qu'une revue RSSI n'a pas validé l'usage (cf. cahier des charges ES-02.5).
OPENAI_API_KEY=

# ─── Authentification JWT iCNS (Prompt 2.1) ─────────────────────────────
# Mode du moteur JWT : "dev" (HMAC-SHA256) ou "hsm" (RSA-PSS via HSM).
# En dev, secret partagé HMAC ≥ 32 caractères.
ICNS_JWT_MODE=dev
ICNS_JWT_DEV_SECRET=

# ─── Chiffrement iCNS (Prompt 2.2) ──────────────────────────────────────
# Mode du service crypto : "dev" (KEK dérivée de passphrase via PBKDF2) ou
# "hsm" (KEK dans HSM PKCS#11, sidecar mTLS).
ICNS_CRYPTO_MODE=dev
# En dev : passphrase ≥ 32 caractères pour dériver la KEK (PBKDF2 200 000 it.).
# Ne JAMAIS réutiliser la même valeur entre dev et prod.
ICNS_KEK_DEV_PASSPHRASE=

# ─── HSM sidecar (mode prod uniquement) ─────────────────────────────────
# Sera implémenté en complément de Phase 2 (livrable M5).
# ICNS_HSM_SIDECAR_URL=https://hsm-sidecar.internal:8443
# ICNS_HSM_SIDECAR_CERT_PATH=/run/secrets/convex-mtls.pem
# ICNS_HSM_SIDECAR_KEY_PATH=/run/secrets/convex-mtls.key
# ICNS_HSM_SIDECAR_CA_PATH=/run/secrets/pki-souveraine-ca.pem

# ─── Identification poste durci (utilisée par LoginCardReader.tsx) ──────
# En prod, chaque poste durci est provisionné avec son IP fixe et son ID.
VITE_POSTE_IP=10.0.0.99
VITE_POSTE_ID=PDG-DEV-001
